# 服务端口
PORT=3232

# TCP 被动监听端口
TCP_PORT=9999

# Web 管理界面密码
WEB_PASSWORD=

# Web 认证密钥
WEB_AUTH_SECRET=

# MySQL 数据库配置
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Alist 配置
ALIST_URL=
ALIST_BASE_PATH=
ALIST_USERNAME=
ALIST_PASSWORD=
ALIST_VERSION_PATH=

# 日志级别
LOG_LEVEL=debug


# HTTPS 配置
HTTPS_ENABLED=false
HTTPS_KEY_PATH=./certs/server.key
HTTPS_CERT_PATH=./certs/server.crt

# 并发配置
SCAN_CONCURRENCY=200
EXTRACT_CONCURRENCY=100
DELETE_CONCURRENCY=100
COMMAND_CONCURRENCY=100
HEARTBEAT_CONCURRENCY=200

# 日志目录
LOG_DIR=./logs

# 扫描端口配置
SCAN_PORTS=9998

# 数据库连接池大小
DB_POOL_SIZE=20

# 更新检查配置
UPDATE_VERSION=
UPDATE_SERVER_IP=
UPDATE_SERVER_PORT=
UPDATE_FILE_PATH=
UPDATE_DOWNLOAD_BASE_URL=

# 日志清理配置
LOG_RETENTION_DAYS=1
SENSITIVE_LOG_SAVE_PATH=./logs/windows_security_saves.txt